# =============================================================
#  TaskOrbit — variables para docker-compose
#  Copiar a la RAIZ del proyecto como `.env`:
#     cp docker/.env.example .env
# =============================================================

# ---- Puertos del HOST (cambiar si chocan con otros proyectos) ----
HOST_HTTP_PORT=8080
HOST_DB_PORT=5433
HOST_ADMINER_PORT=8081

# ---- Subpath de la app (estilo Laragon: nombre de carpeta) ----
# La app se sirve en:  http://localhost:${HOST_HTTP_PORT}${APP_BASE_PATH}
# Cambia esto si quieres otro nombre. Debe iniciar con "/".
# Ejemplos:  /taskorbit   /remtysapp   /miproyecto
APP_BASE_PATH=/taskorbit

# ---- URL completa de la app (DEBE coincidir con HOST_HTTP_PORT + APP_BASE_PATH) ----
# Es leida por public/index.php y por View::asset / Controller::redirect.
# Si cambias el puerto o el subpath, sincroniza esta linea.
APP_URL=http://localhost:8080/taskorbit

# ---- Base de datos (credenciales del contenedor postgres) ----
DB_NAME=taskorbit
DB_USER=taskorbit
DB_PASSWORD=taskorbit_secret
