# ============================================================
# TaskOrbit — Variables de entorno de ejemplo
# Copia este archivo como .env y ajusta los valores
# ============================================================

# Aplicación
APP_NAME=TaskOrbit
APP_URL=http://localhost/taskflow-php/public
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=TaskOrbit
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui

# Sesión
SESSION_NAME=taskorbit_session
SESSION_LIFETIME=7200

# WhatsApp (modo mock por defecto — sin credenciales reales)
# Modos disponibles: mock | real
WHATSAPP_MODE=mock

# Twilio WhatsApp (si WHATSAPP_MODE=real y proveedor=twilio)
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Cloud API (alternativa)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
