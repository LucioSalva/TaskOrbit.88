# ============================================================
# TaskOrbit — Variables de entorno de ejemplo
# SECURITY: Copia este archivo como .env y reemplaza TODOS los
# valores placeholder antes de desplegar a produccion.
# ============================================================

# Aplicacion
APP_NAME=TaskOrbit
APP_URL=http://localhost/taskorbit/public
APP_ENV=local
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_strong_password_here

# Sesion
SESSION_NAME=taskorbit_session
SESSION_LIFETIME=7200

# Notificaciones: umbrales en horas
NOTIFY_UPCOMING_DUE_HOURS=24
NOTIFY_SIN_INICIAR_HOURS=48
NOTIFY_INACTIVITY_HOURS=168
NOTIFY_ESCALATION_HOURS=72

# Semaforo Automatico
SEMAFORO_AMARILLO_DIAS=3
SEMAFORO_INACTIVIDAD_HORAS=48
SEMAFORO_INACTIVIDAD_ROJO_HORAS=120
